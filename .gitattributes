# Auto detect text files and perform LF normalization
* text=auto

# Source code — force LF
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
Dockerfile text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary — don't touch
*.joblib binary
*.db binary
*.csv binary
*.pcap binary
