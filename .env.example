# Backend environment variables (optional)
# Copy to .env and customize

# Database
DATABASE_PATH=flows.db

# Model artifacts
MODEL_DIR=model_artifacts

# Data paths
TRAIN_CSV=../data/processed/train.csv
TEST_CSV=../data/processed/test.csv

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Capture settings
DEFAULT_INTERFACE=eth0
FLOW_TIMEOUT=30

# ML settings
RF_N_ESTIMATORS=100
SMOTE_K_NEIGHBORS=5
CONTAMINATION=0.1
